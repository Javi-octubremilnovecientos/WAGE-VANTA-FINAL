# Copia este archivo como .env y rellena los valores reales.
# Nunca comitees el archivo .env con valores reales.

# URL de tu proyecto Supabase (visible en Dashboard → Settings → API)
VITE_SUPABASE_URL=https://<tu-project-ref>.supabase.co

# Clave anon/publishable de Supabase (segura para el cliente)
# Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_API_KEY=sb_publishable_<tu-anon-key>

# ─── Edge Function secrets (NO van al cliente) ────────────────────────────────
# Estas claves NO se exponen en el bundle. Se configuran en Supabase con:
#   supabase secrets set <NAME>=<value>
# o desde Dashboard → Project Settings → Edge Functions → Secrets.

# Gemini API key (Google AI Studio) — usada por la edge function `enrich-salary-data`
# para enriquecer datos salariales cuando la muestra de TABLE_0 es escasa (< 8).
# Obtener en: https://aistudio.google.com/apikey
# WAGE_VANTAGE_GEMINI_API_KEY=<tu-gemini-key>
