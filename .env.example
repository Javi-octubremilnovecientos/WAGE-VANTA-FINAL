# Copia este archivo como .env y rellena los valores reales.
# Nunca comitees el archivo .env con valores reales.

# URL de tu proyecto Supabase (visible en Dashboard → Settings → API)
VITE_SUPABASE_URL=https://<tu-project-ref>.supabase.co

# Clave anon/publishable de Supabase (segura para el cliente)
# Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_API_KEY=sb_publishable_<tu-anon-key>
